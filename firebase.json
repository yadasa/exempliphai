{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "website/LandingPage/exempliphai/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/__ping",
        "function": "api"
      },
      {
        "source": "/api/createAttribution",
        "function": "createAttribution"
      },
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/r/**",
        "destination": "/r/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
