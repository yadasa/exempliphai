# Firebase web config for the extension (Vite exposes VITE_* at build time)
# Create a Firebase project, enable Phone Auth + Firestore.
# NOTE: These are client-side keys (not secrets), but keep project ids private where possible.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: when using Firebase emulator suite locally
VITE_FIREBASE_USE_EMULATORS=false
VITE_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099
VITE_FIREBASE_FIRESTORE_EMULATOR_HOST=localhost
VITE_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
VITE_FIREBASE_FUNCTIONS_EMULATOR_HOST=localhost
VITE_FIREBASE_FUNCTIONS_EMULATOR_PORT=5001

# Optional: website base URL for referral links shown in the extension
VITE_SITE_BASE_URL=https://exempliphai.com
