{
  "name": "Exempliphai",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Autofill annoying job applications using your saved profile + resume data.",
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "alarms",
    "management"
  ],
  "host_permissions": [
    "https://exempliph.ai/*",
    "https://www.exempliph.ai/*",
    "https://exempliphai.com/*",
    "https://www.exempliphai.com/*",

    "https://us-central1-exempliphai.cloudfunctions.net/*",
    "https://api-cpaddqfnhq-uc.a.run.app/*",
    "https://api.exempliph.ai/*",

    "https://firestore.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firebasestorage.googleapis.com/*"
  ],
  "options_page": "local_profile.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "ai-trigger": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "AI Answer"
    }
  },
  "content_scripts": [
    {
      "js": ["contentScripts/siteAuthBridge.js"],
      "matches": [
        "https://exempliph.ai/*",
        "https://www.exempliph.ai/*",
        "https://exempliphai.com/*",
        "https://www.exempliphai.com/*",
        "http://exempliph.ai/*",
        "http://www.exempliph.ai/*",
        "http://exempliphai.com/*",
        "http://www.exempliphai.com/*"
      ],
      "world": "ISOLATED",
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "js": [
        "contentScripts/atsConfig.js",
        "contentScripts/utils.js",
        "contentScripts/formSnapshot.js",
        "contentScripts/policy.js",
        "contentScripts/fillExecutor.js",
        "contentScripts/aiFillPlan.js",
        "contentScripts/workday.js",
        "contentScripts/autofill.js"
      ],
      "matches": [
        "https://job-boards.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://app.dover.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.oraclecloud.com/*",
        "https://*.successfactors.eu/*",
        "https://*.successfactors.com/*",
        "https://*.recruitee.com/*"
      ],
      "world": "ISOLATED",
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["config/ats_bootstrap.json"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": [
        "contentScripts/fillPlanValidator.js",
        "contentScripts/providers/gemini.js"
      ],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["assets/pdf.worker-*.mjs", "assets/pdf.worker-*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
