{
  "name": "Exempliphai",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Autofill annoying job applications using your saved profile + resume data.",
  "action": {
    "default_popup": "index.html"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "ai-trigger": {
      "suggested_key": {
        "default": "Ctrl+Shift+A"
      },
      "description": "AI Answer"
    }
  },
  "content_scripts": [
    {
      "js": [
        "contentScripts/utils.js",
        "contentScripts/workday.js",
        "contentScripts/autofill.js"
      ],
      "type": "module",
      "matches": [
        "https://job-boards.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://app.dover.com/*",
        "https://*.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.oraclecloud.com/*",
        "https://*.successfactors.eu/*",
        "https://*.successfactors.com/*",
        "https://*.recruitee.com/*"
      ],
      "world": "ISOLATED",
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
