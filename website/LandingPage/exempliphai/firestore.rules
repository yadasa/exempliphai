rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Public landing-page visit logging.
    // Client may only CREATE a visit event doc. Reading is denied.
    match /global/metrics/pageVisits/{visitId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Public aggregate stats used by the hero pill.
    // This doc should be written by a privileged backend (Admin SDK).
    match /publicStats/{docId} {
      allow read: if docId == "aggregate";
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
